// Simule exactement ce qu'on envoie
var fd = new FormData();
fd.append('action', 'favorite');
fd.append('post_id', '69782');
fd.append('site_id', '1');
fd.append('nonce', window.favorites_data.nonce);

fetch(window.favorites_data.ajaxurl, {
    method: 'POST',
    body: fd,
    credentials: 'same-origin'
})
.then(r => r.text())
.then(d => console.log('response:', d))
.catch(e => console.log('error:', e));
