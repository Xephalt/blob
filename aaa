Parfait, j'ai tout ce qu'il me faut. Le nonce c'est `favorites_data.nonce` et l'action AJAX du plugin c'est `favorite` (sans "s"). Corrige le JS :

```javascript
document.addEventListener('DOMContentLoaded', function() {

    var pluginData = window.favorites_data || {};
    var ajaxUrl    = pluginData.ajaxurl || '/wp-admin/admin-ajax.php';
    var nonce      = pluginData.nonce  || '';

    document.querySelectorAll('.bnpp-like-btn').forEach(function(el) {

        el.addEventListener('click', function(e) {
            e.stopPropagation();
            e.preventDefault();

            if (el.dataset.pending === '1') return;
            el.dataset.pending = '1';

            var postId  = el.getAttribute('data-post-id');
            var countEl = el.querySelector('.everylang-count');
            var icon    = el.querySelector('i');

            var formData = new FormData();
            formData.append('action', 'favorite');   // ← sans "s"
            formData.append('post_id', postId);
            formData.append('site_id', '1');
            formData.append('nonce', nonce);

            fetch(ajaxUrl, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                el.dataset.pending = '0';
                // Remplace l'optimiste par le vrai compteur serveur
                if (data && data.count !== undefined && countEl) {
                    countEl.textContent = data.count;
                }
            })
            .catch(function() {
                el.dataset.pending = '0';
            });

            // Optimiste UI
            if (countEl) countEl.textContent = parseInt(countEl.textContent) + 1;
            if (icon) {
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');
            }
            el.style.color = '#2e7d32';
        });
    });
});
```

La seule différence clé : `action: 'favorite'` sans "s". C'est ça qui causait les 400. Le plugin enregistre son handler AJAX sous `wp_ajax_nopriv_favorite` et `wp_ajax_favorite`.
