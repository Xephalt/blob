# ============================================================
# CONFIGURATION — WordPress Link Replacer
# Copie ce fichier et adapte les valeurs à chaque site.
# Ne jamais committer ce fichier (ajoute-le à .gitignore).
# ============================================================

# --- Docker ---
# Nom du container WordPress (celui qui a WP-CLI installé)
WP_CONTAINER="wordpress"

# Nom du container MySQL/MariaDB
DB_CONTAINER="db"

# Chemin vers le répertoire WordPress DANS le container
WP_PATH="/var/www/html"

# --- Base de données ---
DB_HOST="db"           # hostname vu depuis le container WP (souvent le nom du service docker-compose)
DB_NAME="wordpress"
DB_USER="wordpress"
DB_PASS="wordpress"
DB_PREFIX="wp_"        # préfixe des tables WordPress

# --- Comportement du script ---
# Timeout curl en secondes (pour détecter les redirections)
CURL_TIMEOUT=10

# Nombre de redirections max à suivre
CURL_MAX_REDIRS=10

# Mettre à "true" pour exécuter les wp search-replace (false = dry-run, génère juste le mapping)
DO_REPLACE="false"

# Dossier de sortie pour les logs et les fichiers de mapping
OUTPUT_DIR="./output"
